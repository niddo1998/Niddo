# ── Auth0 ─────────────────────────────────────────────
AUTH0_DOMAIN=tu-tenant.us.auth0.com
AUTH0_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AUTH0_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase ───────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
# Usar la "service_role" key (NO la anon). Solo se usa en el backend.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Flask ──────────────────────────────────────────────
# Generá un secreto largo y random: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-un-secreto-largo

# ── Resend (envío de emails) ──────────────────────────
# Registrate en https://resend.com y creá una API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Email de origen (debe estar verificado en Resend)
RESEND_FROM_EMAIL=Niddo <noreply@tu-dominio.com>
